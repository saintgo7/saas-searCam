<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ 데이터 추출 규칙
    클라우드 백업 및 D2D(기기 간 전송)에서 제외할 민감한 파일을 지정한다.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- 스캔 결과 DB는 개인 민감 정보 — 클라우드 백업 제외 -->
        <exclude domain="database" path="searcam.db" />
        <exclude domain="database" path="searcam.db-shm" />
        <exclude domain="database" path="searcam.db-wal" />
        <!-- 앱 설정은 백업 허용 (사용자 편의) -->
    </cloud-backup>
    <device-transfer>
        <!-- D2D 전송에서도 DB 제외 -->
        <exclude domain="database" path="searcam.db" />
    </device-transfer>
</data-extraction-rules>
