<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 11 이하 백업 규칙
    Auto Backup에서 제외할 파일을 지정한다.
-->
<full-backup-content>
    <!-- 스캔 결과 DB는 개인 민감 정보 — 백업 제외 -->
    <exclude domain="database" path="searcam.db" />
    <exclude domain="database" path="searcam.db-shm" />
    <exclude domain="database" path="searcam.db-wal" />
</full-backup-content>
